                  month=\"04\"\r\n                              />\r\n                            </TabPanel>\r\n                            <TabPanel>\r\n                              <DailyAllowanceTableViewSummary\r\n                                year={\r\n                                  selectsiteallowsyear\r\n                                    ? selectsiteallowsyear\r\n                                    : currentyear\r\n                                }\r\n                                month=\"05\"\r\n                              />\r\n                            </TabPanel>\r\n                            <TabPanel>\r\n                              <DailyAllowanceTableViewSummary\r\n                                year={currentyear}\r\n                                month=\"06\"\r\n                              />\r\n                            </TabPanel>\r\n                            <TabPanel>\r\n                              <DailyAllowanceTableViewSummary\r\n                                year={\r\n                                  selectsiteallowsyear\r\n                                    ? selectsiteallowsyear\r\n                                    : currentyear\r\n                                }\r\n                                month=\"07\"\r\n                              />\r\n                            </TabPanel>\r\n                            <TabPanel>\r\n                              <DailyAllowanceTableViewSummary\r\n                                year={\r\n                                  selectsiteallowsyear\r\n                                    ? selectsiteallowsyear\r\n                                    : currentyear\r\n                                }\r\n                                month=\"08\"\r\n                              />\r\n                            </TabPanel>\r\n                            <TabPanel>\r\n                              <DailyAllowanceTableViewSummary\r\n                                ye