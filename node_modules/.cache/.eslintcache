rom \"./employees/useEmployees\";\r\n\r\nconst columns = [\r\n  {\r\n    title: \"Name\",\r\n    field: \"name\",\r\n    cellStyle: {\r\n      width: 200,\r\n      maxWidth: 200,\r\n    },\r\n  },\r\n  { title: \"IC No\", field: \"ic_no\" },\r\n  { title: \"Gender\", field: \"gender\" },\r\n  { title: \"Designation\", field: \"designation\" },\r\n  { title: \"Department\", field: \"department\" },\r\n  { title: \"Leave Entitled\", field: \"leave_entitled\", type: \"numeric\" },\r\n  { title: \"Leave Balance\", field: \"leave_bal\", type: \"numeric\" },\r\n  // { title: \"Email\", field: \"email\" },\r\n];\r\n\r\nexport default function EmployeeTableLeaveView({ year }) {\r\n  const classes = useStyles();\r\n  const { employees, setEmployeeId } = useEmployees();\r\n  const [expdata, setExpData] = useState([]);\r\n  const { expensesperiod, setExpPeriodYrId, setExpPeriodMthId } =\r\n    useExpensesPeriod();\r\n\r\n  \r\n\r\n  return (\r\n    <div className={classes.root}>\r\n      <div style={{ maxWidth: \"100%\", paddingTop: \"5px\" }}>\r\n        <MaterialTable\r\n          columns={columns}\r\n          data={employees.sort((a, b) =>\r\n            a.name > b.name ? 1 : b.name > a.name ? -1 : 0\r\n          )}\r\n          title=\"Expenses Claims\"\r\n          options={{\r\n            filtering: true,\r\n            search: true,\r\n            toolbar: false,\r\n            headerStyle: {\r\n              backgroundColor: \"rgba(75, 192, 192, 1)\",\r\n              color: \"white\",\r\n            },\r\n            showTitle: false,\r\n          }}\r\n        />\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nconst useStyles = makeStyles((theme) => ({\r\n  root: {\r\n    padding: 0,\r\n  },\r\n}));\r\n","D:\\react-myprojects\\hrms-airtable\\src\\components\\ApprovalManager.js",["3136","3137","3138","3139","3140","3141","3142","3143","3144","3145","3146","3147"],"import React, { useState, useEffect } from \"react\";\r\nimport { makeStyles } from \"@material-ui/co